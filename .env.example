# === Required ===
OPENAI_API_KEY=your-openai-api-key-here

# === Optional ===

# Encryption key for persona passwords
# ENCRYPTION_KEY=

# Database (default: SQLite)
DATABASE_URL=sqlite:///./checkmate.db

# LLM settings
LLM_PROVIDER=openai
LLM_MODEL_DEFAULT=gpt-4o
LLM_MODEL_FAST=gpt-4o-mini

# Browser settings
AVAILABLE_BROWSERS=chromium-headless
BROWSER_TIMEOUT=30000
